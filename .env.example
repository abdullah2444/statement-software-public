# Statement Software configuration
# Copy this file to .env, or run ./setup.sh install to create it.

INSTALL_METHOD=docker
PORT=18451
HOST=0.0.0.0
DATA_DIR=./data

DATABASE_PATH=./data/statement_software.db
UPLOAD_DIR=./data/uploads
BACKUP_DIR=./data/backups
MAX_UPLOAD_MB=512

APP_NAME=Statement Software
BRAND_NAME=Statement
COMPANY_NAME=Your Company
DEFAULT_PROFIT_EXPENSE_ACCOUNT_NAME=Company Profit
LEGACY_DATABASE_FILENAME=

# Fresh installs start empty. Set SEED_DEMO_DATA=1 only when you have a demo CSV.
SEED_DEMO_DATA=0
SOURCE_CSV_PATH=
DEMO_CLIENT_NAME=Demo Client

# Generate your own value during setup. Do not commit real secrets.
SECRET_KEY=change-me-with-setup
SESSION_COOKIE_SECURE=0

# Optional integrations
OPENROUTER_API_KEY=
RESET_SECRET_TOKEN=
FX_PROXY_URL=
