# Optional config file for docker-compose.remote.yml.
# Copy this to .env next to compose.yml, edit values, then run:
#   docker compose up -d --build

# Host/browser settings
PORT=18451
HOST=0.0.0.0

# App branding
APP_NAME="Statement Software"
BRAND_NAME="Statement"
COMPANY_NAME="Your Company"
DEFAULT_PROFIT_EXPENSE_ACCOUNT_NAME="Company Profit"

# Runtime behavior
MAX_UPLOAD_MB=512
SESSION_COOKIE_SECURE=0

# First-run admin bootstrap. Only used when the database has no users yet.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin123
INITIAL_ADMIN_MUST_CHANGE=1

# Optional secrets and integrations
SECRET_KEY=
OPENROUTER_API_KEY=
RESET_SECRET_TOKEN=
FX_PROXY_URL=
